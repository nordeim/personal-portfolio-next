    "react-error-boundary": "^6.1.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^24.0.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.29.0",
    "eslint-config-next": "^16.2.6",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
