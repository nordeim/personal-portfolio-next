  "description": "The Engineered Soul — A personal portfolio built with Next.js 16, React 19, and Tailwind CSS v4. Tactile Brutalism design.",
  "author": "Nicholas Yun",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
